rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // HERKES (giriş yapmış) OKUYABİLİR — herkes birbirinin puantajını görebilir
    // ama herkes SADECE KENDİ verisine yazabilir
    match /kullanicilar/{kullaniciId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == kullaniciId;

      match /{altKoleksiyon=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == kullaniciId;
      }
    }
  }
}
